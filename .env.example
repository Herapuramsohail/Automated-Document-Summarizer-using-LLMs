# =============================================
# Environment Variables — Copy to .env to use
# =============================================

# Google Gemini API Key (required)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database (SQLite — path relative to backend/)
DATABASE_URL=sqlite:///./document_summarizer.db

# Upload directory (relative to backend/)
UPLOAD_DIR=./uploads

# FAISS vector index directory (relative to backend/)
VECTOR_DB_DIR=./vector_indices
